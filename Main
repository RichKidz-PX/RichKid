-- LOGIC CORE (Mã hóa phần này)
local Player = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local CollectionService = game:GetService("CollectionService")
local TeleportService = game:GetService("TeleportService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Filename = "SaveSetting_" .. Player.LocalPlayer.UserId .. ".json"
local ErrorChest = {}

-- Khai báo hàm Toàn cục để UI có thể gọi
_G.LoadSetting = function()
    local data = { AutoFarm = false, AutoFarmUntilGetItem = false }
    if isfile(Filename) then
        pcall(function() data = HttpService:JSONDecode(readfile(Filename)) end)
    end
    return data
end

_G.SaveSetting = function(key, value)
    local data = _G.LoadSetting()
    data[key] = value
    writefile(Filename, HttpService:JSONEncode(data))
end

local function HopServer()
    -- Code Hop Server của bạn ở đây...
end

_G.autochest = function()
    local Character = Player.LocalPlayer.Character
    if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
    
    local config = _G.LoadSetting()
    if not config.AutoFarm and not config.AutoFarmUntilGetItem then return end

    -- Code Logic Farm rương của bạn ở đây...
    -- (Copy phần vòng lặp rương từ script cũ của bạn vào đây)
end

-- Vòng lặp chạy ngầm
task.spawn(function()
    while true do
        pcall(_G.autochest)
        task.wait(0.5)
    end
end)

print("Logic đã nạp xong và sẵn sàng!")
