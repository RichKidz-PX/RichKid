-- UI SIDE (Tải trước)
local Player = game:GetService("Players").LocalPlayer
local TweenService = game:GetService("TweenService")

local ScreenGui = Instance.new("ScreenGui", Player:WaitForChild("PlayerGui"))
ScreenGui.Name = "MyScriptUI"
ScreenGui.ResetOnSpawn = false

local Frame = Instance.new("Frame", ScreenGui)
Frame.Size = UDim2.new(0, 220, 0, 86)
Frame.Position = UDim2.new(0.03, 0, 0.17, 0)
Frame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)

local function CreatToggle(name, stringname, PosY)
    local Title = Instance.new("TextLabel", Frame)
    Title.Size = UDim2.new(0, 140, 0, 30)
    Title.Position = UDim2.new(0, 12, 0, PosY)
    Title.Text = name
    Title.TextColor3 = Color3.fromRGB(230, 230, 230)
    Title.BackgroundTransparency = 1
    Title.Font = Enum.Font.GothamSemibold
    Title.TextSize = 12

    local Btn = Instance.new("TextButton", Frame)
    Btn.Size = UDim2.new(0, 42, 0, 20)
    Btn.Position = UDim2.new(1, -52, 0, PosY + 5)
    Btn.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
    Btn.Text = ""

    local Dot = Instance.new("Frame", Btn)
    Dot.Size = UDim2.new(0, 16, 0, 16)
    Dot.Position = UDim2.new(0, 3, 0.5, -8)
    Dot.BackgroundColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(1, 0)

    Btn.MouseButton1Click:Connect(function()
        -- Kiểm tra xem Logic đã nạp chưa trước khi chạy
        if _G.SaveSetting and _G.LoadSetting then
            local currentData = _G.LoadSetting()
            local Boolean = not currentData[stringname]
            
            _G.SaveSetting(stringname, Boolean)
            
            local targetPos = Boolean and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
            local targetColor = Boolean and Color3.fromRGB(80, 200, 120) or Color3.fromRGB(60, 60, 65)
            
            TweenService:Create(Dot, TweenInfo.new(0.2), {Position = targetPos}):Play()
            TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
        else
            warn("Logic đang tải, vui lòng đợi giây lát...")
        end
    end)
end

CreatToggle("Auto Farm", "AutoFarm", 10)
CreatToggle("Auto Get Item", "AutoFarmUntilGetItem", 45)

print("UI đã nạp xong!")
